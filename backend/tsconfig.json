{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "removeComments": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./src",
    "typeRoots": ["./node_modules/@types", "./src/types"] // Đảm bảo compiler quét qua cả file type d khai báo trong src
  },
  "include": ["src/**/*"]
}
